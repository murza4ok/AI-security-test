# Copy this file to .env and fill in your API keys.
# .env is gitignored and must never be committed.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# YandexGPT
YANDEX_API_KEY=...
YANDEX_FOLDER_ID=...
YANDEX_MODEL=yandexgpt-5-lite/latest
# If the key starts with t1. it is treated as an IAM token, otherwise as an API key.

# Request settings
REQUEST_TIMEOUT_SECS=30
REQUEST_DELAY_MS=500
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=4000

# Concurrency inside a single attack category.
# Increase for speed, reduce it if you start seeing 429s.
# CONCURRENCY=1 restores sequential execution.
CONCURRENCY=5
